CREATE OR ALTER PROCEDURE [dbo].[usp_<#= Table.Name #>_Insert]
    <#= string.Join(",\n    ", Table.Columns.Where(c => c.IncludeInInsert).Select(c => c.SqlParameterName + " " + c.SqlFullType)) #>,
    @NewID INT OUTPUT
AS
BEGIN
    SET NOCOUNT ON;

    INSERT INTO [<#= Table.Name #>] (
        <#= string.Join(", ", Table.Columns.Where(c => c.IncludeInInsert).Select(c => "[" + c.Name + "]")) #>
    )
    VALUES (
        <#= string.Join(", ", Table.Columns.Where(c => c.IncludeInInsert).Select(c => c.SqlParameterName)) #>
    );
    
    -- Return the new Identity
    SET @NewID = SCOPE_IDENTITY();
END
GO

