-- 6. EXISTS PROCEDURE
-------------------------------------------------------------
CREATE OR ALTER PROCEDURE [dbo].[usp_<#= Table.Name #>_ExistsByID]
    <#= Table.PrimaryKey.SqlParameterName #> <#= Table.PrimaryKey.SqlFullType #>
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @Res BIT;
    
    SELECT TOP 1 @Res = 1 
    FROM [<#= Table.Name #>]
    WHERE [<#= Table.PrimaryKey.Name #>] = <#= Table.PrimaryKey.SqlParameterName #>;

    SELECT ISNULL(@Res, 0);
END
GO